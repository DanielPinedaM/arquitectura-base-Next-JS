{
  /** configuracion para poder hacer debugging en VS Code */
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "🐞 debugging en Chrome local host",
      "url": "http://localhost:4100",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "start:local"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "🐞 debugging en Chrome pruebas",
      "url": "http://localhost:4100",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "start:test"
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "🐞 debugging en Chrome produccion",
      "url": "http://localhost:4100",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "preLaunchTask": "start:prod"
    }
  ]
}
